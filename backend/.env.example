# ── Database ──────────────────────────────────────────────────────────────────
# Create a dedicated MySQL user — do NOT use root:
#   CREATE USER 'hrms_user'@'localhost' IDENTIFIED BY 'your-password';
#   GRANT ALL PRIVILEGES ON hrms.* TO 'hrms_user'@'localhost';
DB_NAME=hrms
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306

# ── Django ────────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=generate-a-new-key-here

DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Redis ─────────────────────────────────────────────────────────────────────
# Default points to a local Redis instance (db 1).
# Production example: REDIS_URL=redis://:your-password@redis-host:6379/1
REDIS_URL=redis://127.0.0.1:6379/1

# ── Production overrides ──────────────────────────────────────────────────────
# Set ALL of these in your production .env:
#   DEBUG=False
#   ALLOWED_HOSTS=yourdomain.com
#   CORS_ALLOWED_ORIGINS=https://yourdomain.com
#   SECURE_SSL_REDIRECT=True
#   SESSION_COOKIE_SECURE=True
#   CSRF_COOKIE_SECURE=True
#   SECURE_HSTS_SECONDS=31536000
#   SECURE_HSTS_INCLUDE_SUBDOMAINS=True
#   SECURE_HSTS_PRELOAD=True
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
